{
  "React Native Const Component JS": {
    "prefix": "rnconst",
    "description": "Create a React Native const component with StyleSheet.",
    "body": [
      "import React from 'react';",
      "import { StyleSheet, Text, View } from 'react-native';",
      "",
      "const ${1:${TM_FILENAME_BASE/(^|[-_\\.\\s])(\\w)/${2:/upcase}/g}} = (${2:props}) => {",
      "  return (",
      "    <View style={styles.container}>",
      "      <Text>${3:${1}}</Text>",
      "    </View>",
      "  );",
      "};",
      "",
      "export default ${1};",
      "",
      "const styles = StyleSheet.create({",
      "  container: {",
      "    flex: 1,",
      "  },",
      "});"
    ]
  },
  "React Native Export Const Component JS": {
    "prefix": "rnexportconst",
    "description": "Create an exported React Native const component with StyleSheet.",
    "body": [
      "import React from 'react';",
      "import { StyleSheet, Text, View } from 'react-native';",
      "",
      "export const ${1:${TM_FILENAME_BASE/(^|[-_\\.\\s])(\\w)/${2:/upcase}/g}} = (${2:props}) => {",
      "  return (",
      "    <View style={styles.container}>",
      "      <Text>${3:${1}}</Text>",
      "    </View>",
      "  );",
      "};",
      "",
      "const styles = StyleSheet.create({",
      "  container: {",
      "    flex: 1,",
      "  },",
      "});"
    ]
  }
}
